{
  "name": "@dloizides/a11y",
  "version": "0.9.0",
  "description": "The accessibility platform seam for the dloizides.com RN-web UI kit. One authored contract (label/hint/role/state/testID) emitted as platform-correct props: React Native accessibility* on native, real ARIA on web - including the hint, which react-native-web otherwise drops silently because accessibilityHint has no ARIA equivalent. Ships a dual-platform Jest gate that asserts the emitted output under BOTH renderers.",
  "keywords": [
    "accessibility",
    "a11y",
    "aria",
    "react-native",
    "react-native-web",
    "cross-platform",
    "dloizides"
  ],
  "author": "dloizides",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openmindednewby/a11y.git"
  },
  "homepage": "https://github.com/openmindednewby/a11y#readme",
  "bugs": {
    "url": "https://github.com/openmindednewby/a11y/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "browser": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsup",
    "build:watch": "tsup --watch",
    "test": "jest",
    "test:web": "jest --selectProjects web",
    "test:native": "jest --selectProjects native",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "security:audit": "npm audit --audit-level=high",
    "deps:outdated": "npm outdated || exit 0",
    "deps:unused": "npx depcheck --ignores \"@types/jest,@types/node,@types/react,@types/react-dom,rimraf,react-native,react-native-web,react-test-renderer,@react-native/babel-preset,babel-jest,@babel/core,jest-environment-jsdom\"",
    "deps:licenses": "npx license-checker --onlyAllow \"MIT;Apache-2.0;ISC;BSD-2-Clause;BSD-3-Clause;0BSD;Unlicense;CC0-1.0;Python-2.0\"",
    "deps:health": "npm run deps:outdated && npm run deps:unused",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "version": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native/babel-preset": "^0.81.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.32",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0",
    "react-test-renderer": "^19.2.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
